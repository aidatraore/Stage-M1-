############################################################
# 5) Concaténation FOYER
############################################################
rule concatenate_foyer:
    input:
        primary   = expand("results_foyer2/{sample}_primary.fasta",   sample=SAMPLES_FOYER),
        secondary = expand("results_foyer2/{sample}_secondary.fasta", sample=SAMPLES_FOYER),
        consensus = expand("results_foyer2/{sample}_consensus.fasta", sample=SAMPLES_FOYER),
    output:
        all_primary   = "results_foyer2/all_primary.fasta",
        all_secondary = "results_foyer2/all_secondary.fasta",
        all_consensus = "results_foyer2/all_consensus.fasta",
    shell:
        """
        cat {input.primary}   > {output.all_primary}
        cat {input.secondary} > {output.all_secondary}
        cat {input.consensus} > {output.all_consensus}
        """

